# =============================================================================
# Claims Processing Assistant - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables show their default behaviour.
# =============================================================================

# ── API Keys & Authentication ────────────────────────────────────────────────

OPENAI_API_KEY=your-openai-api-key            # [REQUIRED] OpenAI API key
ANTHROPIC_API_KEY=your-anthropic-key          # [REQUIRED] Anthropic API key (for judge model)
LANGSMITH_API_KEY=your-langsmith-key          # [REQUIRED] LangSmith API key for tracing

# ── Model Configuration ──────────────────────────────────────────────────────

OPENAI_MODEL_NAME=gpt-4o-mini                 # Primary LLM model
JUDGE_MODEL_NAME=claude-3-sonnet              # Judge/evaluator model

# ── LangSmith / LangChain Observability ──────────────────────────────────────

LANGSMITH_TRACING=true                        # Enable LangSmith tracing
LANGCHAIN_PROJECT=claimprocessing             # LangSmith / LangChain project name
TRACE_SAMPLE_RATE=1.0                         # Trace sampling rate (0.0 - 1.0; 1.0 = trace all)

# ── Application Settings ─────────────────────────────────────────────────────

LOG_LEVEL=INFO                                # Log level: DEBUG / INFO / WARNING / ERROR / CRITICAL
ENABLE_STRUCTURED_LOGGING=true                # When true, uses JSON logging (app/logging/json_logger.py)
ENABLE_LATENCY_METRICS=true                   # When true, enables latency/metrics hooks (Phase 6)
SQLITE_DB_PATH=claims.db                      # Path to SQLite database file
ENVIRONMENT=dev                               # Runtime environment: dev / test / prod

# ── RAG / Vector Store Settings ────────────────────────────────────────────────

OPENAI_EMBEDDING_MODEL=text-embedding-3-small # Embedding model for knowledge base
VECTOR_BACKEND=faiss                          # Vector store backend: faiss / chroma / pinecone
PINECONE_API_KEY=your-pinecone-api-key        # Pinecone API key (if using Pinecone)
