# =============================================================================
# Claims Processing Assistant - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables show their default behaviour.
# =============================================================================

# ── API Keys & Authentication ────────────────────────────────────────────────

OPENAI_API_KEY=your-openai-api-key            # [REQUIRED] OpenAI API key
ANTHROPIC_API_KEY=your-anthropic-key          # [REQUIRED] Anthropic API key (for judge model)
LANGSMITH_API_KEY=your-langsmith-key          # [REQUIRED] LangSmith API key for tracing

# ── Model Configuration ──────────────────────────────────────────────────────

OPENAI_MODEL_NAME=gpt-4o-mini                 # Primary LLM model
JUDGE_MODEL_NAME=claude-* model/llama              # Judge/evaluator model

# ── LangSmith / LangChain Observability ──────────────────────────────────────

LANGSMITH_TRACING=true                        # Enable LangSmith tracing
LANGCHAIN_PROJECT=claimprocessing             # LangSmith / LangChain project name
TRACE_SAMPLE_RATE=1.0                         # Trace sampling rate (0.0 - 1.0; 1.0 = trace all)

# ── Application Settings ─────────────────────────────────────────────────────

LOG_LEVEL=INFO                                # Log level: DEBUG / INFO / WARNING / ERROR / CRITICAL
ENABLE_STRUCTURED_LOGGING=true                # When true, uses JSON logging (app/logging/json_logger.py)
ENABLE_LATENCY_METRICS=true                   # When true, enables latency/metrics hooks (Phase 6)
SQLITE_DB_PATH=data/claims.db                 # Path to SQLite database file
ENVIRONMENT=dev                               # Runtime environment: dev / test / prod

# ── RAG / Vector Store Settings ────────────────────────────────────────────────

OPENAI_EMBEDDING_MODEL=text-embedding-3-small # Embedding model for knowledge base
EMBEDDING_MODEL_VERSION=text-embedding-3-small@2024-02-15 # Version-pinned embedding model (must match between ingestion & query)
VECTOR_BACKEND=faiss                          # Vector store backend: faiss / chroma / pinecone
PINECONE_API_KEY=your-pinecone-api-key        # Pinecone API key (if using Pinecone)

# ── RAG Evaluation Harness ─────────────────────────────────────────────────

RAG_EVALUATION_CONTEXT=claims / insurance    # One of: loan underwriting, customer svc, aml / fraud, claims / insurance
RAG_EVALUATION_HIT_RATE_THRESHOLD=0.85       # Minimum Hit Rate @ 5 for a case to pass
RAG_EVALUATION_MRR_THRESHOLD=0.65            # Minimum MRR for a case to pass
RAG_EVALUATION_FAITHFULNESS_THRESHOLD=0.90   # Minimum faithfulness score for a case to pass
RAG_EVALUATION_ANSWER_CORRECTNESS_THRESHOLD=0.80 # Minimum answer correctness score for a case to pass
RAG_EVALUATION_LLM_JUDGE_AVG_THRESHOLD=4.0   # Minimum LLM judge average (/5) for a case to pass
RAG_EVALUATION_CITATION_COVERAGE_THRESHOLD=1.0 # Minimum citation coverage for a case to pass
RAG_EVALUATION_MIN_CITATIONS=1               # Minimum citations expected in an accepted answer
RAG_EVALUATION_OUTPUT_PATH=scripts/rag_evaluation_results.json # Optional output file path
